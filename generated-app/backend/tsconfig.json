{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@aws-news-hub/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "seed.ts"],
  "exclude": ["node_modules", "dist"]
}
